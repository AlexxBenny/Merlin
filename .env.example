# ─────────────────────────────────────────────────────────────
# MERLIN API Keys — Example Configuration
# ─────────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your API keys.
#
# Key resolution order (per role, per LLM call):
#   1. api_key in config/models.yaml     (inline, highest priority)
#   2. {PROVIDER}_{ROLE}_API_KEYS        (role-specific, round-robin)
#   3. {PROVIDER}_API_KEYS               (shared pool, round-robin)
#   4. {PROVIDER}_API_KEY                (singular fallback)
#
# Plural keys are comma-separated for round-robin RPM rotation.
#
# ─────────────────────────────────────────────────────────────
# Roles (defined in config/models.yaml):
#
#   mission_compiler       Decomposes + compiles user queries into IR
#   cognitive_coordinator  Pre-phase: decides DIRECT vs SKILL_PLAN
#   content_generator      reasoning.generate_text skill (stories, etc.)
#   report_generator       Formats execution results for user
#   clarifier              Generates clarification questions
#
# Each role can use a different provider (ollama/openrouter/gemini).
# Only cloud providers (openrouter/gemini/huggingface) need API keys.
# Ollama runs locally — no key needed.
# ─────────────────────────────────────────────────────────────

# ── OpenRouter (https://openrouter.ai/) ──
# Shared fallback (used by any openrouter role without a specific key)
OPENROUTER_API_KEY=

# Per-role keys (optional — set these to distribute RPM across keys)
# OPENROUTER_MISSION_COMPILER_API_KEYS=key1,key2
# OPENROUTER_COGNITIVE_COORDINATOR_API_KEYS=key3
# OPENROUTER_CONTENT_GENERATOR_API_KEYS=key4,key5,key6
# OPENROUTER_REPORT_GENERATOR_API_KEYS=key7
# OPENROUTER_CLARIFIER_API_KEYS=key8

# ── Google Gemini (https://aistudio.google.com/apikey) ──
# GEMINI_API_KEY=
# GEMINI_MISSION_COMPILER_API_KEYS=
# GEMINI_REPORT_GENERATOR_API_KEYS=
# GEMINI_CLARIFIER_API_KEYS=

# ── HuggingFace (https://huggingface.co/settings/tokens) ──
# HUGGINGFACE_API_KEY=

# ── Email Integration ──
# Required for email skills. Credentials never stored in YAML.
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_USERNAME=
# EMAIL_PASSWORD=
# EMAIL_FROM_ADDRESS=
